---
interface Props { lang?: string; }
const { lang = 'zh-CN' } = Astro.props;
const isEn = lang === 'en';
---

<section class="qs-section">
  <div class="kk-container">
    <div class="qs-tag">{isEn ? '[7] Quick Start' : '[7] 快速开始'}</div>
    <h2>{isEn ? 'Three steps to launch' : '三步开跑'}</h2>
    <div class="term">
      <div class="line"><span class="c">#</span> <span class="d">{isEn ? 'Install with one command' : '一条命令装好'}</span></div>
      <div class="line cmd">brew install tw93/tap/kaku</div>
      <div class="line"><span class="c">#</span> <span class="d">{isEn ? 'Or grab the DMG' : '或者直接下 DMG'}</span></div>
      <div class="line cmd"><a href={isEn ? '/Kaku/en/download' : '/Kaku/download'}>kaku.site/download</a></div>
      <div class="line"><span class="c">#</span> <span class="d">{isEn ? 'Open and go' : '打开即用'}</span></div>
      <div class="line cmd">kaku</div>
    </div>
    <p>{isEn ? 'After install, Kaku auto-configures your shell environment — no extra steps needed.' : '装好之后 Kaku 会自动配置你的 shell 环境，无需任何额外步骤。'}</p>
  </div>
</section>

<style>
  .qs-section {
    padding: var(--kk-space-16) 0;
    border-bottom: 1px dashed var(--kk-border);
  }
  .qs-tag {
    color: var(--kk-accent);
    font-family: var(--kk-font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    opacity: 0.7;
    margin-bottom: var(--kk-space-3);
    text-align: center;
  }
  h2 {
    color: var(--kk-text);
    font-size: 24px;
    text-align: center;
    margin: 0 0 var(--kk-space-8);
  }
  .term {
    background: #000;
    border: 1px solid var(--kk-border-strong);
    border-radius: var(--kk-radius-md);
    padding: var(--kk-space-6);
    font-family: var(--kk-font-mono);
    font-size: 13px;
    max-width: 520px;
    margin: 0 auto var(--kk-space-4);
  }
  .line { margin-bottom: var(--kk-space-2); }
  .line:last-child { margin-bottom: 0; }
  .c { color: var(--kk-text-muted); }
  .d { color: var(--kk-text-muted); }
  .cmd { color: var(--kk-accent); }
  .cmd a { color: var(--kk-accent); text-decoration: underline; }
  p {
    color: var(--kk-text-dim);
    font-size: 13px;
    text-align: center;
    max-width: 520px;
    margin: 0 auto;
  }
</style>
